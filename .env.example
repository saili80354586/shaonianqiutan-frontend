# API Base URL used by frontend runtime.
# Local default uses Vite proxy; direct backend access can use http://127.0.0.1:8080/api.
VITE_API_BASE_URL=/api

# Legacy name is still supported by code for compatibility, but new config should use VITE_API_BASE_URL.
# VITE_API_URL=/api

# Vite dev proxy target for /api and /ws.
VITE_DEV_API_TARGET=http://localhost:8080
VITE_DEV_SERVER_PORT=5173

# WebSocket endpoint or host. Leave empty when /ws is served by the same frontend origin/proxy.
# Examples: localhost:8080, ws://localhost:8080/ws, wss://api.example.com/ws
VITE_WS_URL=
